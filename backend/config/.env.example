# Application Mode: "dev_1" | "dev_2" | "prod"
#   dev_1 — JSON file as ES substitute (no Elasticsearch needed)
#   dev_2 — local Elasticsearch service
#   prod  — production
MODE=dev_1

# OpenAI API Key (used for embeddings)
OPENAI_API_KEY=

# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=agentmatch
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200

# Redis
REDIS_URL=redis://localhost:6379/0
