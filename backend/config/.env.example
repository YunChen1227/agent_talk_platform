# Application Mode: "dev_1" | "dev_2" | "prod"
#   dev_1 — JSON file as ES substitute (no Elasticsearch needed)
#   dev_2 — local Elasticsearch service
#   prod  — production
MODE=dev_1

# OpenAI API Key (chat / tags LLM; not used for embeddings)
OPENAI_API_KEY=

# Local OpenAI-compatible embedding service (e.g. python embedding/embedding_server.py)
EMBEDDING_API_URL=http://127.0.0.1:8830/v1/embeddings
# Vector dimension (must match model, e.g. Qwen3-Embedding-0.6B → 1024)
EMBEDDING_DIM=1024

# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=agentmatch
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200

# Redis
REDIS_URL=redis://localhost:6379/0
