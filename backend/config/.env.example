# Application Mode: "dev" (JSON storage) or "prod" (PostgreSQL)
MODE=dev

# OpenAI API Key (used for embeddings in prod mode)
OPENAI_API_KEY=

# PostgreSQL (prod mode only)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=agentmatch
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
